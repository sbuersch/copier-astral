[project]
name = "{{ project_slug }}"
version = "0.1.0"
description = "{{ description }}"
readme = "README.md"
requires-python = ">={{ python_version }}"
authors = [
    { name = "{{ author_name }}", email = "{{ author_email }}" },
]
dependencies = [
    "django~={{ django_version }}",
    {% if use_postgres %}"psycopg[binary]~=3.2",{% endif %}
    {% if use_allauth %}"django-allauth~=65.0",{% endif %}
    {% if use_rest_framework %}"djangorestframework~=3.15",{% endif %}
    {% if use_debug_toolbar %}"django-debug-toolbar~=4.4",{% endif %}
    {% if use_celery %}"celery~=5.4",{% endif %}
    {% if use_redis %}"redis~=5.0",{% endif %}
    "python-dotenv~=1.0",
    "gunicorn~=21.2",
]

[project.scripts]
manage = "{{ project_slug }}.manage:main"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.ruff]
line-length = 88
target-version = "py{{ python_version|replace('.', '') }}"

[tool.ruff.lint]
select = ["E", "F", "B", "C4", "ARG", "SIM"]
ignore = []

[tool.ty]
python_version = "{{ python_version }}"

[tool.ty.serialization]
report = [
    { format = "concise", output = "-" },
]

[tool.pytest.ini_options]
minversion = "7.0"
addopts = "-ra -q --tb=short"
testpaths = [
    "tests",
]
python_files = "test_*.py"
python_classes = "Test*"
python_functions = "test_*"