# Django settings
DJANGO_SECRET_KEY=your-secret-key-here-change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

{% if use_postgres %}
# Database settings
DB_NAME={{ project_slug }}
DB_USER=postgres
